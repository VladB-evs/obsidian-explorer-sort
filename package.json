{
	"name": "explorer-sort",
	"version": "1.0.0",
	"description": "Obsidian plugin for manually arranging files and folders in the file explorer.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": ["obsidian", "plugin", "sort", "file-explorer"],
	"author": "Vlad Bacila",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"monkey-around": "^2.3.0"
	}
}
